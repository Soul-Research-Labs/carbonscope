# CarbonScope Frontend — Environment Variables (production)
#
# Copy to .env.production.local and fill in real values.

# Backend API URL — REQUIRED in production
BACKEND_URL=https://api.carbonscope.io

# Public site URL (used for sitemap, OG tags, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://carbonscope.io

# Web Vitals telemetry endpoint (optional)
# NEXT_PUBLIC_VITALS_ENDPOINT=https://api.carbonscope.io/api/v1/telemetry

# Disable Next.js telemetry in production
NEXT_TELEMETRY_DISABLED=1
