# CarbonScope Frontend — Environment Variables (staging)
#
# Copy to .env.staging.local and fill in real values.

# Backend API URL
BACKEND_URL=https://staging-api.carbonscope.io

# Public site URL
NEXT_PUBLIC_SITE_URL=https://staging.carbonscope.io

# Web Vitals telemetry endpoint (optional)
# NEXT_PUBLIC_VITALS_ENDPOINT=https://staging-api.carbonscope.io/api/v1/telemetry

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1
